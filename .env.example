# Copy this file to `.env` and fill in your keys.
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/macOS)

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
TOGETHER_BASE_URL=https://api.together.xyz/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Keyword ranking (embedding-based). Disable with 0 to keep VLM keyword order only.
STEP_SIMILARITY_ENABLED=1
STEP_SIMILARITY_MODEL=sentence-transformers/all-MiniLM-L6-v2
STEP_SIMILARITY_METRIC=manhattan
STEP_SIMILARITY_TOPK=5

# Hybrid video keyword re-ranker weights: embedding similarity (0.45),
# LLM/VLM ranking via RRF (0.55). Rule-hit scoring is disabled for the
# production video path; legacy three-part values are still accepted.
STEP_RERANK_WEIGHTS=0.45,0.55

# Disable video analysis and embedding cache during manual runtime tests.
STEP_DISABLE_VIDEO_CACHE=0

# VLM selection (recommended: gemini for handwritten stability)
VLM_PROVIDER=gemini
TOGETHER_VLM_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
TOGETHER_VLM_FALLBACK_MODEL=

# Optional
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
